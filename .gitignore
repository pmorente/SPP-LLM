# Keep specific important files
!experiment_*/SPP_example.json
!experiment_*/input.csv
!experiment_*/requirements.txt
!experiment_*/README.md

# IMPORTANT: Explicitly allow results and outputs folders and ALL their contents
# These negation patterns must come AFTER the ignore patterns above
!**/results/
!**/outputs/
!**/results/**
!**/outputs/**
!**/results/**/*
!**/outputs/**/*

# CPU compiled binaries (experiment_2/post_analyse/CPU/)
experiment_2/post_analyse/CPU/compare_one_to_one
experiment_2/post_analyse/CPU/*.o
experiment_2/post_analyse/CPU/**/*.o

# Keep source files
!experiment_2/post_analyse/CPU/*.cpp
!experiment_2/post_analyse/CPU/*.hpp
!experiment_2/post_analyse/CPU/README.md
